# Loaded automatically by `next dev` (local development only).
# Vercel/production builds use dashboard env vars instead — keep ADMIN_MODE=false there.
NEXT_PUBLIC_ADMIN_MODE=true
NEXT_PUBLIC_PRELAUNCH=true
# Local wizard — uncomment for localhost V3 testing (BTI, user confirmed, feedback)
NEXT_PUBLIC_WIZARD_URL=https://api.exportgateway.eu
NEXT_PUBLIC_API_BASE_URL=https://api.exportgateway.eu

EXPORT_AUDITOR_API_URL=http://127.0.0.1:8013
