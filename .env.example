# Environment variables
NEXT_PUBLIC_WIZARD_URL=https://export-compliance-wizard.onrender.com
NEXT_PUBLIC_API_BASE_URL=https://export-compliance-wizard.onrender.com

# Export Auditor — dedicated OCR + audit API (server-side only)
EXPORT_AUDITOR_API_URL=https://export-auditor.onrender.com

# Mistral OCR cost per page (USD) — observability cost estimates
MISTRAL_OCR_COST_PER_PAGE_USD=0.002

# Enterprise Export 3.0 — AI declaration descriptions (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_APP_URL=https://exportgateway.com

# Mapbox — required for live route maps in Freight & Intrastat tools
# Create a public token restricted to your domains in the Mapbox dashboard
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Server-side Mapbox (geocoding + directions fallback). Same token or secret scope token.
MAPBOX_ACCESS_TOKEN=
